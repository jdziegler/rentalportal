generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Stripe Billing (platform subscription)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // Stripe Connect (rent collection)
  stripeConnectId      String?   @unique
  stripeConnectOnboarded Boolean @default(false)

  properties   Property[]
  contacts     Contact[]
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
  maintenanceRequests MaintenanceRequest[]
  rentScheduleConfig  RentScheduleConfig?
  messages     Message[]
  screeningRequests ScreeningRequest[]
  ownedTeams   Team[]       @relation("TeamOwner")
  teamMemberships TeamMember[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Property Management ──

model Property {
  id          String  @id @default(cuid())
  userId      String
  name        String
  type        Int     @default(2)  // 1=single, 2=multi
  year        String?
  currency    String  @default("USD")
  address     String
  city        String
  state       String
  zip         String
  county      String?
  country     String  @default("US")
  description String?
  amenities   Json    @default("[]")
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  units        Unit[]
  transactions Transaction[]
  listings     Listing[]
  maintenanceRequests MaintenanceRequest[]
}

model Unit {
  id          String  @id @default(cuid())
  propertyId  String
  name        String
  type        Int     @default(1)
  bedrooms    Int?
  bathrooms   Int?
  size        Int?
  price       Decimal?  @db.Decimal(10, 2)
  deposit     Decimal?  @db.Decimal(10, 2)
  description String?
  isRented    Boolean @default(false)
  features    Json    @default("[]")
  petsAllowed Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
  maintenanceRequests MaintenanceRequest[]
}

model Contact {
  id         String  @id @default(cuid())
  userId     String
  role       String  @default("tenant")  // tenant, professional, owner
  firstName  String
  lastName   String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zip        String?
  status     Int     @default(0)  // 0=pending, 1=invited, 2=active, 3=inactive
  notes      String?
  archivedAt DateTime?

  // Stripe (tenant payment method)
  stripeCustomerId String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]
  maintenanceRequests MaintenanceRequest[]
  autoPayConfigs AutoPayConfig[]
  messages       Message[]
  signatures     Signature[]
  screeningRequests ScreeningRequest[]
}

model Lease {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String?
  unitId      String
  contactId   String
  name        String?
  leaseType   Int      @default(1)  // 1=fixed, 2=month-to-month
  leaseStatus Int      @default(0)  // 0=active, 1=expired, 2=terminated
  rentAmount  Decimal  @db.Decimal(10, 2)
  rentPeriod  Int      @default(5)  // 5=monthly
  rentDueDay  Int      @default(1)
  gracePeriod Int      @default(5)  // days after due date before considered overdue
  currency    String   @default("USD")
  rentFrom    DateTime
  rentTo      DateTime?
  deposit     Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Late fee config (embedded on lease for simplicity)
  lateFeeEnabled   Boolean @default(false)
  lateFeeType      String  @default("flat")    // "flat" or "percentage"
  lateFeeAmount    Decimal @default(0) @db.Decimal(10, 2)  // dollar amount or percentage
  lateFeeAccrual   String  @default("one_time") // "one_time" or "daily"
  lateFeeMaxAmount Decimal? @db.Decimal(10, 2)  // cap for daily accrual

  // Tenant portal
  paymentToken String?  @unique @default(uuid())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  autoPayConfig AutoPayConfig?
  messages      Message[]
  documents     LeaseDocument[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String?
  unitId      String?
  leaseId     String?
  contactId   String?
  category    String   // income, expense
  subcategory String?  // rent, late_fee, deposit, repair, utility, insurance, management, other
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  date        DateTime
  paidAt      DateTime?
  paid        Decimal  @default(0) @db.Decimal(10, 2)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  details     String?
  note        String?
  isRecurring Boolean  @default(false)
  status      Int      @default(0)

  // Automation fields
  source        String?   // "auto_rent", "auto_late_fee", "manual", null
  billingPeriod String?   // "2026-03" format for idempotency
  parentId      String?   // links late fee to its rent charge
  retryCount    Int       @default(0)

  // Stripe payment tracking
  stripePaymentIntentId String?
  stripePaymentStatus   String?  // succeeded, processing, pending, failed
  paymentMethod         String?  // ach, card, cash, check, etc.

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit     Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease    Lease?        @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  parent   Transaction?  @relation("LateFeeParent", fields: [parentId], references: [id], onDelete: SetNull)
  lateFees Transaction[] @relation("LateFeeParent")
  payments Payment[]

  @@unique([leaseId, billingPeriod, source], name: "lease_period_source_unique")
}

model Payment {
  id            String   @id @default(cuid())
  transactionId String
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime @default(now())
  method        String?  // cash, check, ach, card, other
  note          String?
  type          String   @default("payment") // payment, refund

  // Stripe tracking (one PaymentIntent per payment)
  stripePaymentIntentId String?  @unique
  stripePaymentStatus   String?  // succeeded, processing, failed

  createdAt DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Listing {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  unitId      String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model MaintenanceRequest {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  unitId      String?
  contactId   String?
  title       String
  description String?
  priority    Int      @default(1)  // 0=low, 1=medium, 2=high, 3=urgent
  status      Int      @default(0)  // 0=open, 1=in_progress, 2=completed, 3=cancelled
  category    String?  // plumbing, electrical, hvac, appliance, general, etc.
  cost        Decimal? @db.Decimal(10, 2)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

// ── Rent Automation ──

model AutoPayConfig {
  id                    String   @id @default(cuid())
  leaseId               String   @unique
  contactId             String
  enabled               Boolean  @default(true)
  paymentMethodType     String   @default("us_bank_account") // "us_bank_account" or "card"
  stripePaymentMethodId String
  maxRetries            Int      @default(2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lease   Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model RentScheduleConfig {
  id         String  @id @default(cuid())
  userId     String  @unique
  publishDay Int     @default(1)  // day of month to create rent charges (1-28)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Tenant Portal ──

model TenantVerification {
  id         String   @id @default(cuid())
  identifier String   // email or phone number
  code       String   // 6-digit code
  type       String   // "email" or "sms"
  expiresAt  DateTime
  attempts   Int      @default(0) // track failed attempts
  createdAt  DateTime @default(now())

  @@index([identifier, code])
}

model Message {
  id        String   @id @default(cuid())
  userId    String   // landlord
  contactId String   // tenant contact
  leaseId   String?  // optional lease context
  body      String
  sender    String   // "landlord" or "tenant"
  readAt    DateTime?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lease   Lease?  @relation(fields: [leaseId], references: [id], onDelete: SetNull)
}

// ── Lease Documents & E-Signatures ──

model LeaseDocument {
  id         String   @id @default(cuid())
  leaseId    String
  userId     String   // landlord who uploaded
  name       String   // original filename
  fileType   String   // mime type (application/pdf, image/jpeg, etc.)
  fileSize   Int      // bytes
  filePath   String   // path on disk (uploads/<userId>/<id>.<ext>)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lease      Lease      @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  signatures Signature[]

  @@index([leaseId])
}

model Signature {
  id          String    @id @default(cuid())
  documentId  String
  contactId   String    // tenant who needs to sign
  status      String    @default("pending") // pending, signed, declined
  signedAt    DateTime?
  declinedAt  DateTime?
  ipAddress   String?   // audit trail
  userAgent   String?   // audit trail
  signatureData String? // base64 PNG of drawn signature
  signingToken  String  @unique @default(uuid()) // unique link for tenant
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document LeaseDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  contact  Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([documentId, contactId])
  @@index([signingToken])
}

// ── Teams & Permissions ──

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   // User who created the team
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TeamMember[]
  invites TeamInvite[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("viewer") // owner, manager, viewer, maintenance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvite {
  id        String    @id @default(cuid())
  teamId    String
  email     String
  role      String    @default("viewer")
  token     String    @unique @default(uuid())
  status    String    @default("pending") // pending, accepted, expired
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

// ── Tenant Screening ──

model ScreeningRequest {
  id          String   @id @default(cuid())
  userId      String   // landlord
  contactId   String   // tenant being screened
  provider    String   @default("mock") // mock, transunion, checkr
  status      String   @default("pending") // pending, consent_sent, processing, completed, failed, expired
  consentToken String  @unique @default(uuid())
  consentedAt  DateTime?
  completedAt  DateTime?
  expiresAt    DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reports ScreeningReport[]

  @@index([userId, contactId])
}

model ScreeningReport {
  id          String   @id @default(cuid())
  requestId   String
  type        String   // credit, criminal, eviction
  status      String   @default("clear") // clear, review, alert
  score       Int?     // credit score (300-850)
  summary     String?  // human-readable summary
  details     Json?    // full report data
  createdAt   DateTime @default(now())

  request ScreeningRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model CronJobLog {
  id          String    @id @default(cuid())
  jobType     String    // "rent_generation", "auto_payment", "late_fee"
  status      String    // "started", "completed", "failed"
  details     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

// ── Stripe Webhook Idempotency ──

model WebhookEvent {
  id          String   @id // Stripe event ID (evt_xxx)
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// ── Notifications ──

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  channel   String   // "email" or "sms"
  type      String   // rent_reminder, rent_overdue, payment_received, etc.
  status    String   // "sent", "failed", "bounced"
  error     String?
  recipient String   // email address or phone number
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([contactId, type])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   // landlord who owns the contact
  contactId    String   // tenant
  emailEnabled Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  disabledTypes Json    @default("[]") // array of NotificationType strings to suppress
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, contactId], name: "userId_contactId")
}
