generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  properties   Property[]
  contacts     Contact[]
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Property Management ──

model Property {
  id          String  @id @default(cuid())
  userId      String
  name        String
  type        Int     @default(2)  // 1=single, 2=multi
  year        String?
  currency    String  @default("USD")
  address     String
  city        String
  state       String
  zip         String
  county      String?
  country     String  @default("US")
  description String?
  amenities   Json    @default("[]")
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  units        Unit[]
  transactions Transaction[]
  listings     Listing[]
}

model Unit {
  id          String  @id @default(cuid())
  propertyId  String
  name        String
  type        Int     @default(1)
  bedrooms    Int?
  bathrooms   Int?
  size        Int?
  price       Decimal?  @db.Decimal(10, 2)
  deposit     Decimal?  @db.Decimal(10, 2)
  description String?
  isRented    Boolean @default(false)
  features    Json    @default("[]")
  petsAllowed Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
}

model Contact {
  id         String  @id @default(cuid())
  userId     String
  role       String  @default("tenant")  // tenant, professional, owner
  firstName  String
  lastName   String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zip        String?
  status     Int     @default(0)  // 0=pending, 1=invited, 2=active
  notes      String?
  archivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]
}

model Lease {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String?
  unitId      String
  contactId   String
  name        String?
  leaseType   Int      @default(1)  // 1=fixed, 2=month-to-month
  leaseStatus Int      @default(0)  // 0=active, 1=expired, 2=terminated
  rentAmount  Decimal  @db.Decimal(10, 2)
  rentPeriod  Int      @default(5)  // 5=monthly
  rentDueDay  Int      @default(1)
  currency    String   @default("USD")
  rentFrom    DateTime
  rentTo      DateTime?
  deposit     Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String?
  unitId      String?
  leaseId     String?
  contactId   String?
  category    String   // income, expense
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  date        DateTime
  paidAt      DateTime?
  paid        Decimal  @default(0) @db.Decimal(10, 2)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  details     String?
  note        String?
  isRecurring Boolean  @default(false)
  status      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease    Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Listing {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  unitId      String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
}
