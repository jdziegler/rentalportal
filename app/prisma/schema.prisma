generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──

enum LeaseStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum LeaseType {
  FIXED
  MONTH_TO_MONTH
}

enum TransactionStatus {
  UNPAID
  PAID
  PARTIAL
  PENDING
  WAIVED
  VOIDED
}

enum ContactStatus {
  PENDING
  INVITED
  ACTIVE
  INACTIVE
}

enum PropertyType {
  SINGLE_FAMILY
  MULTI_FAMILY
  COMMERCIAL
}

enum UnitType {
  APARTMENT
  HOUSE
  ROOM
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RentPeriod {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ── Auth (NextAuth) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Stripe Billing (platform subscription)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?

  // Stripe Connect (rent collection)
  stripeConnectId      String?   @unique
  stripeConnectOnboarded Boolean @default(false)

  properties   Property[]
  contacts     Contact[]
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
  maintenanceRequests MaintenanceRequest[]
  rentScheduleConfig  RentScheduleConfig?
  messages     Message[]
  screeningRequests ScreeningRequest[]
  ownedTeams   Team[]       @relation("TeamOwner")
  teamMemberships TeamMember[]
  uploads      Upload[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Property Management ──

model Property {
  id          String       @id @default(cuid())
  tcId        Int?         @unique
  userId      String
  name        String
  type        PropertyType @default(MULTI_FAMILY)
  year        String?
  currency    String       @default("USD")
  address     String
  city        String
  state       String
  zip         String
  county      String?
  country     String       @default("US")
  lat         Float?
  lng         Float?
  yearBuilt   Int?
  description String?
  photoUrl    String?
  amenities   Json         @default("[]")
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  units        Unit[]
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
  maintenanceRequests MaintenanceRequest[]

  @@index([userId])
}

model Unit {
  id          String   @id @default(cuid())
  tcId        Int?     @unique
  propertyId  String
  name        String
  type        UnitType @default(APARTMENT)
  bedrooms    Int?
  bathrooms   Int?
  size        Int?
  price       Decimal? @db.Decimal(10, 2)
  deposit     Decimal? @db.Decimal(10, 2)
  description String?
  isRented    Boolean  @default(false)
  features    Json     @default("[]")
  petsAllowed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  transactions Transaction[]
  listings     Listing[]
  maintenanceRequests MaintenanceRequest[]

  @@index([propertyId])
}

model Contact {
  id         String        @id @default(cuid())
  tcId       Int?          @unique
  userId     String
  role       String        @default("tenant")
  firstName  String
  lastName   String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  zip        String?
  status     ContactStatus @default(PENDING)
  notes      String?
  archivedAt DateTime?

  // Stripe (tenant payment method)
  stripeCustomerId String?

  // Additional fields
  dateOfBirth      DateTime?
  emergencyContact String?
  moveInDate       DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases       Lease[]
  leaseTenants LeaseTenant[]
  transactions Transaction[]
  maintenanceRequests MaintenanceRequest[]
  autoPayConfigs AutoPayConfig[]
  messages       Message[]
  signatures     Signature[]
  screeningRequests ScreeningRequest[]

  @@index([userId, status])
}

model Lease {
  id          String      @id @default(cuid())
  tcId        Int?        @unique
  userId      String
  propertyId  String?
  unitId      String
  contactId   String
  name        String?
  leaseType   LeaseType   @default(FIXED)
  leaseStatus LeaseStatus @default(ACTIVE)
  rentAmount  Decimal     @db.Decimal(10, 2)
  rentPeriod  RentPeriod  @default(MONTHLY)
  rentDueDay  Int         @default(1)
  gracePeriod Int         @default(5)
  currency    String      @default("USD")
  startDate   DateTime
  endDate     DateTime?
  deposit     Decimal?    @db.Decimal(10, 2)
  moveOutDate DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Renewal tracking
  previousLeaseId String?  @unique
  previousLease   Lease?  @relation("LeaseRenewal", fields: [previousLeaseId], references: [id], onDelete: SetNull)
  renewedLease    Lease?  @relation("LeaseRenewal")

  // Late fee config
  lateFeeEnabled   Boolean @default(false)
  lateFeeType      String  @default("flat")
  lateFeeAmount    Decimal @default(0) @db.Decimal(10, 2)
  lateFeeAccrual   String  @default("one_time")
  lateFeeMaxAmount Decimal? @db.Decimal(10, 2)

  // Tenant portal
  paymentToken String? @unique @default(uuid())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Restrict)
  tenants      LeaseTenant[]
  transactions Transaction[]
  autoPayConfig AutoPayConfig?
  messages      Message[]
  documents     LeaseDocument[]

  @@index([userId, leaseStatus])
  @@index([unitId, leaseStatus])
  @@index([contactId])
}

model LeaseTenant {
  id        String   @id @default(cuid())
  leaseId   String
  contactId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  lease   Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([leaseId, contactId])
  @@index([contactId])
}

model Transaction {
  id          String            @id @default(cuid())
  tcId        Int?              @unique
  userId      String
  propertyId  String?
  unitId      String?
  leaseId     String?
  contactId   String?
  category    String
  subcategory String?
  amount      Decimal           @db.Decimal(10, 2)
  currency    String            @default("USD")
  date        DateTime
  paidAt      DateTime?
  paidAmount  Decimal           @default(0) @db.Decimal(10, 2)
  balance     Decimal           @default(0) @db.Decimal(10, 2)
  details     String?
  note        String?
  isRecurring Boolean           @default(false)
  status      TransactionStatus @default(UNPAID)

  // Automation fields
  source        String?
  billingPeriod String?
  parentId      String?
  retryCount    Int       @default(0)

  // Stripe payment tracking
  stripePaymentIntentId String?
  stripePaymentStatus   String?
  paymentMethod         String?

  // Void tracking
  voidedAt   DateTime?
  voidReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit     Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease    Lease?        @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  parent   Transaction?  @relation("LateFeeParent", fields: [parentId], references: [id], onDelete: SetNull)
  lateFees Transaction[] @relation("LateFeeParent")
  payments Payment[]

  @@unique([leaseId, billingPeriod, source], name: "lease_period_source_unique")
  @@index([userId, date])
  @@index([userId, status])
  @@index([leaseId])
  @@index([contactId])
  @@index([propertyId])
}

model Payment {
  id            String   @id @default(cuid())
  tcId          Int?     @unique
  transactionId String
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime @default(now())
  method        String?
  note          String?
  type          String   @default("payment")
  status        String?

  // Stripe tracking
  stripePaymentIntentId String? @unique
  stripePaymentStatus   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model Listing {
  id          String   @id @default(cuid())
  tcId        Int?     @unique
  userId      String
  propertyId  String
  unitId      String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  userId      String
  propertyId  String
  unitId      String?
  contactId   String?
  title       String
  description String?
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  category    String?
  cost        Decimal?            @db.Decimal(10, 2)
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

// ── Rent Automation ──

model AutoPayConfig {
  id                    String   @id @default(cuid())
  leaseId               String   @unique
  contactId             String
  enabled               Boolean  @default(true)
  paymentMethodType     String   @default("us_bank_account")
  stripePaymentMethodId String
  maxRetries            Int      @default(2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  lease   Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model RentScheduleConfig {
  id         String  @id @default(cuid())
  userId     String  @unique
  publishDay Int     @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Tenant Portal ──

model TenantVerification {
  id         String   @id @default(cuid())
  identifier String
  code       String
  type       String
  expiresAt  DateTime
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([identifier, code])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  leaseId   String?
  body      String
  sender    String
  readAt    DateTime?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lease   Lease?  @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([contactId])
  @@index([leaseId])
}

// ── Lease Documents & E-Signatures ──

model LeaseDocument {
  id         String   @id @default(cuid())
  leaseId    String
  userId     String
  name       String
  fileType   String
  fileSize   Int
  filePath   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lease      Lease      @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  signatures Signature[]

  @@index([leaseId])
}

model Signature {
  id          String    @id @default(cuid())
  documentId  String
  contactId   String
  status      String    @default("pending")
  signedAt    DateTime?
  declinedAt  DateTime?
  ipAddress   String?
  userAgent   String?
  signatureData String?
  signingToken  String  @unique @default(uuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document LeaseDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  contact  Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([documentId, contactId])
  @@index([signingToken])
}

// ── Teams & Permissions ──

model Team {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TeamMember[]
  invites TeamInvite[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  userId String
  role   String @default("viewer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvite {
  id        String    @id @default(cuid())
  teamId    String
  email     String
  role      String    @default("viewer")
  token     String    @unique @default(uuid())
  status    String    @default("pending")
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

// ── Tenant Screening ──

model ScreeningRequest {
  id          String   @id @default(cuid())
  userId      String
  contactId   String
  provider    String   @default("mock")
  status      String   @default("pending")
  consentToken String  @unique @default(uuid())
  consentedAt  DateTime?
  completedAt  DateTime?
  expiresAt    DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reports ScreeningReport[]

  @@index([userId, contactId])
}

model ScreeningReport {
  id          String   @id @default(cuid())
  requestId   String
  type        String
  status      String   @default("clear")
  score       Int?
  summary     String?
  details     Json?
  createdAt   DateTime @default(now())

  request ScreeningRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model CronJobLog {
  id          String    @id @default(cuid())
  jobType     String
  status      String
  details     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}

// ── Stripe Webhook Idempotency ──

model WebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// ── Notifications ──

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  contactId String
  channel   String
  type      String
  status    String
  error     String?
  recipient String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([contactId, type])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String
  contactId    String
  emailEnabled Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  disabledTypes Json    @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, contactId], name: "userId_contactId")
}

// ── File Storage ──

model Upload {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  url       String
  size      Int      // bytes
  mimeType  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Audit Trail ──

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Transaction, Lease, etc.
  entityId  String
  changes   Json?    // { field: { old: x, new: y } }
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
}
